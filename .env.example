# Postgres (Neon pooled — app runtime)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stravai?schema=public&pgbouncer=true"

# Postgres direct — migrations only (Neon: host without -pooler)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/stravai?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# GitHub OAuth app (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Canonical app URL (required in production; optional locally)
AUTH_URL="http://localhost:3000"

# CLI / VS Code extension
STRAVAI_URL="http://localhost:3000"
STRAVAI_TOKEN=""
