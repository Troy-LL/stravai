{
  "name": "stravai",
  "displayName": "StravAI",
  "description": "Track coding workouts and post sessions to StravAI",
  "version": "0.2.0",
  "publisher": "stravai",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:stravai.startSession",
    "onCommand:stravai.stopSession"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stravai.startSession",
        "title": "StravAI: Start Session"
      },
      {
        "command": "stravai.stopSession",
        "title": "StravAI: Stop Session"
      }
    ],
    "configuration": {
      "title": "StravAI",
      "properties": {
        "stravai.apiUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "StravAI API base URL"
        },
        "stravai.token": {
          "type": "string",
          "default": "",
          "description": "API token from StravAI Settings (sai_...)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.3"
  }
}
